# MongoDB Configuration
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB=advanced-ui

# Admin Configuration
ADMIN_KEY=admin123

# Server Port
PORT=3000

# Node Environment
NODE_ENV=development

# === Email OTP (required on Render — SMTP ports 587/465 are BLOCKED) ===
# Sign up: https://resend.com → API Keys → create key → add on Render
RESEND_API_KEY=re_xxxxxxxxxxxx
# Test without domain: FairFoods <onboarding@resend.dev>
# After verifying fairfoods.in in Resend: FairFoods <noreply@fairfoods.in>
RESEND_FROM=FairFoods <onboarding@resend.dev>

# Gmail SMTP — local dev only (does NOT work on Render free tier)
SMTP_EMAIL=your-email@gmail.com
SMTP_PASSWORD=your-16-char-app-password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
